---
import { getRelativeLocaleUrl } from 'astro:i18n';
import { LOCALES, DEFAULT_LOCALE } from '../i18n/config';

const defaultTarget = getRelativeLocaleUrl(DEFAULT_LOCALE, '');
const localeMap = Object.fromEntries(
  LOCALES.map((l) => [l, getRelativeLocaleUrl(l, '')])
) as Record<string, string>;
---

<!DOCTYPE html>
<html lang={DEFAULT_LOCALE}>
  <head>
    <meta charset="utf-8" />
    <meta http-equiv="refresh" content={`0; url=${defaultTarget}`} />
    <link rel="canonical" href={defaultTarget} />
    <title>Redirecting…</title>
    <script is:inline define:vars={{ defaultTarget, localeMap }}>
      try {
        const pref = (navigator.languages && navigator.languages[0]) || navigator.language || '';
        const tag = String(pref).toLowerCase();
        let chosen = defaultTarget;
        for (const code of Object.keys(localeMap)) {
          if (tag === code || tag.startsWith(code + '-')) {
            chosen = localeMap[code];
            break;
          }
        }
        window.location.replace(chosen);
      } catch (e) {
        window.location.replace(defaultTarget);
      }
    </script>
  </head>
  <body>
    <p>Redirecting…</p>
  </body>
</html>
