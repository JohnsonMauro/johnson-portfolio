---
import { getAbsoluteLocaleUrl, getRelativeLocaleUrl } from 'astro:i18n';
import BaseLayout from '../../app/layouts/BaseLayout.astro';
import Sidebar from '../../features/sidebar/Sidebar';
import BackToTop from '../../features/back-to-top/BackToTop';
import Hero from '../../widgets/hero/Hero.astro';
import About from '../../widgets/about/About.astro';
import Skills from '../../widgets/skills/Skills.astro';
import Resume from '../../widgets/resume/Resume.astro';
import Footer from '../../widgets/footer/Footer.astro';
import { profile } from '../../domain/profile/profile';
import { LOCALES, type Locale, isLocale } from '../../domain/i18n/config';
import { getDict } from '../../domain/i18n/content';
import { personJsonLd } from '../../domain/seo/jsonld';
import { asset } from '../../shared/lib/asset';

export function getStaticPaths() {
  return LOCALES.map((lang) => ({ params: { lang } }));
}

const { lang } = Astro.params;
if (!isLocale(lang)) {
  throw new Error(`Unsupported locale: ${lang}`);
}

const typedLang = lang as Locale;
const dict = getDict(typedLang);

const localeUrls = Object.fromEntries(
  LOCALES.map((l) => [l, getRelativeLocaleUrl(l, '')])
) as Record<Locale, string>;

const absoluteCanonical = getAbsoluteLocaleUrl(typedLang, '');
const imageAbsolute = new URL(asset(profile.photo), Astro.site).toString();
const jsonLd = personJsonLd({
  name: profile.name,
  lang: typedLang,
  url: absoluteCanonical,
  imageUrl: imageAbsolute,
  jobTitle: dict.meta.jobTitle,
  description: dict.meta.description,
  email: profile.email,
  sameAs: [profile.social.linkedin, profile.social.github, profile.social.medium],
});
---

<BaseLayout
  lang={typedLang}
  title={dict.meta.title}
  description={dict.meta.description}
  keywords={dict.meta.keywords}
  jsonLd={jsonLd}
>
  <Sidebar
    client:load
    name={profile.name}
    photo={asset(profile.photo)}
    social={profile.social}
    email={profile.email}
    homeHref={localeUrls[typedLang]}
    mailSubject={dict.meta.mailSubject}
    navLabels={dict.nav}
    lang={typedLang}
    localeUrls={localeUrls}
    langSwitchLabel={dict.nav.languageSwitcherLabel}
    themeToggleLabel={dict.nav.themeToggleLabel}
    themeToggleToDark={dict.nav.themeToggleToDark}
    themeToggleToLight={dict.nav.themeToggleToLight}
    cvHref={getRelativeLocaleUrl(typedLang, 'cv')}
    printCvLabel={dict.nav.printCv}
    printCvShort={dict.nav.printCvShort}
  />
  <Hero dict={dict} />
  <main>
    <About dict={dict} lang={typedLang} />
    <Skills dict={dict} />
    <Resume dict={dict} />
  </main>
  <Footer />
  <BackToTop client:idle />
</BaseLayout>
