---
import { getRelativeLocaleUrl } from 'astro:i18n';
import Base from '../../layouts/Base.astro';
import Sidebar from '../../components/Sidebar';
import Hero from '../../sections/Hero.astro';
import About from '../../sections/About.astro';
import Skills from '../../sections/Skills.astro';
import Resume from '../../sections/Resume.astro';
import Footer from '../../components/Footer.astro';
import BackToTop from '../../components/BackToTop';
import { profile } from '../../data/profile';
import { LOCALES, type Locale, isLocale } from '../../i18n/config';
import { getDict } from '../../i18n/content';

export function getStaticPaths() {
  return LOCALES.map((lang) => ({ params: { lang } }));
}

const { lang } = Astro.params;
if (!isLocale(lang)) {
  throw new Error(`Unsupported locale: ${lang}`);
}

const typedLang = lang as Locale;
const dict = getDict(typedLang);

const baseRaw = import.meta.env.BASE_URL.replace(/\/$/, '');
const asset = (p: string) => `${baseRaw}/${p.replace(/^\//, '')}`;

const localeUrls = Object.fromEntries(
  LOCALES.map((l) => [l, getRelativeLocaleUrl(l, '')])
) as Record<Locale, string>;
---

<Base
  lang={typedLang}
  title={dict.meta.title}
  description={dict.meta.description}
  keywords={dict.meta.keywords}
>
  <Sidebar
    client:load
    name={profile.name}
    photo={asset(profile.photo)}
    social={profile.social}
    email={profile.email}
    homeHref={localeUrls[typedLang]}
    mailSubject={dict.meta.mailSubject}
    navLabels={dict.nav}
    lang={typedLang}
    localeUrls={localeUrls}
    langSwitchLabel={dict.nav.languageSwitcherLabel}
  />
  <Hero dict={dict} />
  <main>
    <About dict={dict} />
    <Skills dict={dict} />
    <Resume dict={dict} />
  </main>
  <Footer />
  <BackToTop client:idle />
</Base>
