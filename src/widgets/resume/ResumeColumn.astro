---
import type { ResumeEntry } from '../../domain/i18n/content';
import FadeIn from '../../shared/ui/FadeIn';

interface Props {
  items: ResumeEntry[];
}

const { items } = Astro.props;
---

<ol class="relative border-l-2 border-accent/30 pl-6">
  {
    items.map((item, idx) => (
      <FadeIn client:visible variant="fade-up" delay={idx * 80} as="li" className="relative pb-8 last:pb-0">
        <span
          class="absolute -left-[33px] top-1.5 flex h-4 w-4 items-center justify-center rounded-full border-2 border-accent bg-surface"
          aria-hidden="true"
        />
        <h4 class="font-display text-lg font-semibold text-ink-deep">{item.role}</h4>
        <p class="mt-0.5 inline-block rounded-full bg-accent/10 px-2.5 py-0.5 text-xs font-medium text-accent-dark">
          {item.period}
        </p>
        <p class="mt-1 text-sm italic text-ink/70">
          {item.url ? (
            <a
              href={item.url}
              target="_blank"
              rel="noopener noreferrer"
              class="inline-flex items-center gap-1 text-ink/70 underline-offset-2 transition hover:text-accent hover:underline focus-visible:outline-none focus-visible:ring-2 focus-visible:ring-accent"
            >
              {item.org}
              <svg
                xmlns="http://www.w3.org/2000/svg"
                viewBox="0 0 24 24"
                width="12"
                height="12"
                fill="none"
                stroke="currentColor"
                stroke-width="2"
                stroke-linecap="round"
                stroke-linejoin="round"
                aria-hidden="true"
                class="inline-block translate-y-[-1px]"
              >
                <path d="M14 3h7v7" />
                <path d="M10 14 21 3" />
                <path d="M21 14v6a1 1 0 0 1-1 1H4a1 1 0 0 1-1-1V4a1 1 0 0 1 1-1h6" />
              </svg>
            </a>
          ) : (
            item.org
          )}
        </p>
        {item.bullets && (
          <ul class="mt-3 list-disc space-y-1 pl-4 text-sm text-ink/80 marker:text-accent">
            {item.bullets.map((b) => (
              <li>{b}</li>
            ))}
          </ul>
        )}
      </FadeIn>
    ))
  }
</ol>
