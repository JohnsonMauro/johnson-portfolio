---
import ResumeColumn from './ResumeColumn.astro';
import type { Dict } from '../../domain/i18n/content';

interface Props {
  dict: Dict;
}

const { dict } = Astro.props;

const half = Math.ceil(dict.resume.length / 2);
const left = dict.resume.slice(0, half);
const right = dict.resume.slice(half);
---

<section
  id="resume"
  class="section-anchor bg-surface py-20 px-6 xl:pl-[calc(theme(spacing.sidebar)+theme(spacing.6))]"
>
  <div class="mx-auto max-w-page">
    <header class="mb-10">
      <h2 class="font-display text-4xl font-bold text-ink-deep">{dict.sections.experienceTitle}</h2>
      <div class="mt-2 h-1 w-12 rounded-full bg-accent"></div>
    </header>

    <div class="grid gap-10 lg:grid-cols-2">
      <ResumeColumn items={left} />
      <ResumeColumn items={right} />
    </div>
  </div>
</section>
