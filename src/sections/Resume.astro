---
import { resume, type ResumeItem } from '../data/profile';
import ResumeColumn from '../components/ResumeColumn.astro';

const half = Math.ceil(resume.length / 2);
const left: ResumeItem[] = resume.slice(0, half);
const right: ResumeItem[] = resume.slice(half);
---

<section
  id="resume"
  class="section-anchor bg-white py-20 px-6 xl:pl-[calc(theme(spacing.sidebar)+theme(spacing.6))]"
>
  <div class="mx-auto max-w-page">
    <header class="mb-10">
      <h2 class="font-display text-4xl font-bold text-ink-deep">Experience</h2>
      <div class="mt-2 h-1 w-12 rounded-full bg-accent"></div>
    </header>

    <div class="grid gap-10 lg:grid-cols-2">
      <ResumeColumn items={left} />
      <ResumeColumn items={right} />
    </div>
  </div>
</section>
