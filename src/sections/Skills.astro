---
import { skills } from '../data/profile';
import ProgressBar from '../components/ProgressBar';
import type { Dict } from '../i18n/content';

interface Props {
  dict: Dict;
}

const { dict } = Astro.props;

const half = Math.ceil(skills.length / 2);
const left = skills.slice(0, half);
const right = skills.slice(half);
---

<section
  id="skills"
  class="section-anchor bg-slate-50 py-20 px-6 xl:pl-[calc(theme(spacing.sidebar)+theme(spacing.6))]"
>
  <div class="mx-auto max-w-page">
    <header class="mb-10">
      <h2 class="font-display text-4xl font-bold text-ink-deep">{dict.sections.skillsTitle}</h2>
      <div class="mt-2 h-1 w-12 rounded-full bg-accent"></div>
    </header>

    <div class="grid gap-x-12 md:grid-cols-2">
      <div>
        {left.map((s) => <ProgressBar client:visible label={s.name} value={s.value} />)}
      </div>
      <div>
        {right.map((s) => <ProgressBar client:visible label={s.name} value={s.value} />)}
      </div>
    </div>
  </div>
</section>
