---
import { profile } from '../data/profile';
import FadeIn from '../components/FadeIn';
import type { Dict } from '../i18n/content';

interface Props {
  dict: Dict;
}

const { dict } = Astro.props;

const base = import.meta.env.BASE_URL.replace(/\/$/, '');
const asset = (p: string) => `${base}/${p.replace(/^\//, '')}`;
---

<section
  id="about"
  class="section-anchor bg-white py-20 px-6 xl:pl-[calc(theme(spacing.sidebar)+theme(spacing.6))]"
>
  <div class="mx-auto max-w-page">
    <header class="mb-10">
      <h2 class="font-display text-4xl font-bold text-ink-deep">{dict.sections.aboutTitle}</h2>
      <div class="mt-2 h-1 w-12 rounded-full bg-accent"></div>
      <p class="mt-4 text-lg">{dict.about.greeting}</p>
      <p class="mt-3 max-w-3xl text-ink/80">{dict.about.summary}</p>
    </header>

    <div class="grid gap-10 lg:grid-cols-12">
      <FadeIn client:visible variant="fade-right" className="lg:col-span-4" as="div">
        <img
          src={asset(profile.photo)}
          alt={profile.name}
          width={360}
          height={360}
          class="w-full max-w-sm rounded-2xl object-cover shadow-md"
        />
      </FadeIn>
      <FadeIn client:visible variant="fade-left" className="lg:col-span-8" as="div">
        <p class="text-ink/80">{dict.about.current}</p>
        <dl class="mt-6 space-y-4">
          {
            dict.about.expertise.map((item) => (
              <div>
                <dt class="font-display text-sm font-semibold uppercase tracking-wide text-ink-deep">
                  {item.label}
                </dt>
                <dd class="mt-1 text-ink/80">{item.value}</dd>
              </div>
            ))
          }
        </dl>
      </FadeIn>
    </div>
  </div>
</section>
