---
import { profile } from '../data/profile';

const base = import.meta.env.BASE_URL.replace(/\/$/, '');
const asset = (p: string) => `${base}/${p.replace(/^\//, '')}`;
---

<i class="bi bi-list mobile-nav-toggle d-xl-none"></i>

<header id="header">
  <div class="d-flex flex-column">
    <div class="profile">
      <img src={asset(profile.photo)} alt={profile.name} class="img-fluid rounded-circle" />
      <h1 class="text-light"><a href={`${base}/`}>{profile.name}</a></h1>
      <div class="social-links mt-3 text-center">
        <a href={profile.social.linkedin} target="_blank" rel="noopener" class="linkedin"
          ><i class="bx bxl-linkedin"></i></a>
        <a href={profile.social.github} target="_blank" rel="noopener" class="github"
          ><i class="bx bxl-github"></i></a>
        <a href={profile.social.medium} target="_blank" rel="noopener" class="medium"
          ><i class="bx bxs-news"></i></a>
        <a
          href={`mailto:${profile.email}?subject=Mail from johnsonmauro.github.io`}
          class="mail"><i class="bx bx-mail-send"></i></a>
      </div>
    </div>

    <nav id="navbar" class="nav-menu navbar">
      <ul>
        <li><a href="#hero" class="nav-link scrollto active"><i class="bx bx-home"></i> <span>Home</span></a></li>
        <li><a href="#about" class="nav-link scrollto"><i class="bx bx-user"></i> <span>About</span></a></li>
        <li><a href="#resume" class="nav-link scrollto"><i class="bx bx-file-blank"></i> <span>Experience</span></a></li>
      </ul>
    </nav>
  </div>
</header>
